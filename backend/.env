FRONTEND_ORIGIN=http://localhost:5173
API_PAGE_SIZE=20
THROTTLE_ANON=50/min
THROTTLE_USER=200/min
THROTTLE_LOGIN=10/min
LOG_LEVEL=INFO

POSTGRES_DB=planora
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_URL=memory
USE_SQLITE=1

# AI Assistant - use Groq (fast cloud) with Ollama fallback
AI_PROVIDER=groq
GROQ_API_KEY= <ADD YOUR API KEY HERE>
