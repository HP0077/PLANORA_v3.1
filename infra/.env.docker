# Docker environment defaults — copy to ../backend/.env and customise
DJANGO_SECRET_KEY=CHANGE-ME-TO-A-RANDOM-64-CHAR-STRING
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_ORIGIN=http://localhost

API_PAGE_SIZE=20
THROTTLE_ANON=50/min
THROTTLE_USER=200/min
THROTTLE_LOGIN=10/min
LOG_LEVEL=INFO

POSTGRES_DB=planora
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
USE_SQLITE=0

REDIS_URL=redis://redis:6379/0

SECURE_HSTS_SECONDS=31536000
